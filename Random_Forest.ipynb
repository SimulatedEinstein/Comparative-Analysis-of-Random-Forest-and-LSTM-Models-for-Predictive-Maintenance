# ================================
# IMPORT LIBRARIES
# ================================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

from sklearn.preprocessing import MinMaxScaler
from sklearn.ensemble import RandomForestRegressor
from sklearn.metrics import mean_squared_error, r2_score

# ================================
# LOAD DATA
# ================================
train = pd.read_csv("/content/train_FD001.txt", sep="\s+", header=None)
test = pd.read_csv("/content/test_FD001.txt", sep="\s+", header=None)
rul = pd.read_csv("/content/RUL_FD001.txt", header=None)

# ================================
# COLUMN NAMES
# ================================
cols = ['engine_id', 'cycle'] + \
       [f'op{i}' for i in range(1,4)] + \
       [f'sensor{i}' for i in range(1,22)]

train.columns = cols
test.columns = cols

# ================================
# CREATE RUL FOR TRAINING
# ================================
max_cycle = train.groupby('engine_id')['cycle'].max().reset_index()
max_cycle.columns = ['engine_id', 'max_cycle']

train = train.merge(max_cycle, on='engine_id')
train['RUL'] = train['max_cycle'] - train['cycle']

# Clip RUL
train['RUL'] = train['RUL'].clip(upper=125)

# ================================
# FEATURE SCALING
# ================================
features = train.columns.difference(['engine_id','cycle','RUL','max_cycle'])

scaler = MinMaxScaler()
train[features] = scaler.fit_transform(train[features])
test[features] = scaler.transform(test[features])

# ================================
# TRAIN RANDOM FOREST
# ================================
rf = RandomForestRegressor(
    n_estimators=100,
    max_depth=15,
    random_state=42,
    n_jobs=-1
)

rf.fit(train[features], train['RUL'])

# ================================
# PREDICT
# ================================
rf_pred_all = rf.predict(test[features])

test['rf_pred'] = rf_pred_all

# ONE PREDICTION PER ENGINE
final_pred = test.groupby('engine_id')['rf_pred'].last().values

# ================================
# DEBUG LENGTH CHECK
# ================================
actual = rul.values.flatten()

print("Actual length:", len(actual))
print("Prediction length:", len(final_pred))

# ================================
# FIX LENGTH IF NEEDED
# ================================
min_len = min(len(actual), len(final_pred))
actual = actual[:min_len]
final_pred = final_pred[:min_len]

# ================================
# METRICS
# ================================
rmse = np.sqrt(mean_squared_error(actual, final_pred))
r2 = r2_score(actual, final_pred)

print("\nRandom Forest RMSE:", rmse)
print("Random Forest R2 Score:", r2)

# ================================
# FEATURE IMPORTANCE
# ================================
importances = rf.feature_importances_
feat_imp = pd.Series(importances, index=features).sort_values(ascending=False)

plt.figure(figsize=(8,5))
feat_imp.head(10).plot(kind='bar')
plt.title("Top 10 Important Features")
plt.xlabel("Features")
plt.ylabel("Importance")
plt.grid()
plt.show()

# ================================
# PLOT RESULTS (WITH METRICS)
# ================================
plt.figure(figsize=(10,5))
plt.plot(actual, label="Actual RUL", linewidth=2)
plt.plot(final_pred, label="RF Predicted", linewidth=2)

plt.title(f"Random Forest Results\nRMSE = {rmse:.2f}, R² = {r2:.3f}")
plt.xlabel("Engine Index")
plt.ylabel("RUL")

plt.legend()
plt.grid()
plt.show()
