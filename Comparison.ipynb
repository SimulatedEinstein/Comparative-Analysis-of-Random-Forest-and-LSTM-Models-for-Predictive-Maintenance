# ================================
# SAFE FINAL COMPARISON CELL
# ================================
import numpy as np
import matplotlib.pyplot as plt
from sklearn.metrics import mean_squared_error

# -------------------------------
# CHECK / RECREATE RF PREDICTION
# -------------------------------
try:
    rf_final
except NameError:
    print("Recomputing Random Forest predictions...")

    rf_pred_all = rf.predict(test[features])
    test['rf_pred'] = rf_pred_all
    rf_final = test.groupby('engine_id').last()['rf_pred'].values

# -------------------------------
# CHECK LSTM PREDICTION
# -------------------------------
try:
    lstm_pred
except NameError:
    raise ValueError(" lstm_pred not found. Please run LSTM cell first.")

# -------------------------------
# PREPARE DATA
# -------------------------------
actual = rul.values.flatten()

rf_pred = rf_final[:len(actual)]
lstm_pred = lstm_pred[:len(actual)]

# -------------------------------
# RMSE CALCULATION
# -------------------------------
rmse_rf = np.sqrt(mean_squared_error(actual, rf_pred))
rmse_lstm = np.sqrt(mean_squared_error(actual, lstm_pred))

print("Random Forest RMSE:", rmse_rf)
print("LSTM RMSE:", rmse_lstm)

# -------------------------------
# MODEL COMPARISON
# -------------------------------
if rmse_lstm < rmse_rf:
    print("\n LSTM is more accurate")
else:
    print("\n Random Forest is more accurate")

# -------------------------------
# PLOT COMPARISON
# -------------------------------
plt.figure(figsize=(12,6))

plt.plot(actual, label="Actual RUL", linewidth=2)
plt.plot(rf_pred, label="Random Forest", linestyle="--")
plt.plot(lstm_pred, label="LSTM", linestyle=":")

plt.legend()
plt.title("Model Comparison: RF vs LSTM")
plt.xlabel("Engine Index")
plt.ylabel("RUL")
plt.grid()

plt.show()
