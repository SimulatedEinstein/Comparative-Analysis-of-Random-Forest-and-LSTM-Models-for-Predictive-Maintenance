# ================================
# IMPORT LIBRARIES
# ================================
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt

from sklearn.preprocessing import MinMaxScaler
from sklearn.metrics import mean_squared_error, r2_score  

import tensorflow as tf
from tensorflow.keras.models import Sequential
from tensorflow.keras.layers import LSTM, Dense, Dropout
from tensorflow.keras.optimizers import Adam

# ================================
# GPU SETUP
# ================================
print("TensorFlow version:", tf.__version__)
print("GPU Available:", tf.config.list_physical_devices('GPU'))

gpus = tf.config.list_physical_devices('GPU')
if gpus:
    for gpu in gpus:
        tf.config.experimental.set_memory_growth(gpu, True)

# ================================
# LOAD DATA
# ================================
train = pd.read_csv("/content/train_FD002.txt", sep="\s+", header=None)
test = pd.read_csv("/content/test_FD002.txt", sep="\s+", header=None)
rul = pd.read_csv("/content/RUL_FD002.txt", header=None)

# ================================
# COLUMN NAMES
# ================================
cols = ['engine_id', 'cycle'] + \
       [f'op{i}' for i in range(1,4)] + \
       [f'sensor{i}' for i in range(1,22)]

train.columns = cols
test.columns = cols

# ================================
# CREATE RUL
# ================================
max_cycle = train.groupby('engine_id')['cycle'].max().reset_index()
max_cycle.columns = ['engine_id', 'max_cycle']

train = train.merge(max_cycle, on='engine_id')
train['RUL'] = train['max_cycle'] - train['cycle']
train['RUL'] = train['RUL'].clip(upper=125)

# ================================
# FEATURE SCALING
# ================================
features = train.columns.difference(['engine_id','cycle','RUL','max_cycle'])

scaler = MinMaxScaler()
train[features] = scaler.fit_transform(train[features])
test[features] = scaler.transform(test[features])

# ================================
# NORMALIZE TARGET
# ================================
train['RUL'] = train['RUL'] / 125.0

# ================================
# CREATE SEQUENCES
# ================================
def create_sequences(df, seq_length, features):
    X, y = [], []
    for engine_id in df['engine_id'].unique():
        engine_data = df[df['engine_id'] == engine_id].reset_index(drop=True)

        for i in range(len(engine_data) - seq_length):
            X.append(engine_data.loc[i:i+seq_length-1, features].values)
            y.append(engine_data.loc[i+seq_length, 'RUL'])

    return np.array(X), np.array(y)

seq_length = 30
X_train, y_train = create_sequences(train, seq_length, features)

print("Training shape:", X_train.shape)

# ================================
# CALLBACK
# ================================
class PrintEvery100Epochs(tf.keras.callbacks.Callback):
    def on_epoch_end(self, epoch, logs=None):
        if (epoch + 1) % 100 == 0:
            print(f"Epoch {epoch+1}: Loss = {logs['loss']:.5f}, Val Loss = {logs['val_loss']:.5f}")

# ================================
# BUILD + TRAIN MODEL
# ================================
with tf.device('/GPU:0'):

    model = Sequential([
        LSTM(128, return_sequences=True, input_shape=(seq_length, len(features))),
        Dropout(0.3),
        LSTM(64),
        Dropout(0.3),
        Dense(1)
    ])

    model.compile(optimizer=Adam(learning_rate=0.001), loss='mse')

    history = model.fit(
        X_train, y_train,
        epochs=1000,
        batch_size=64,
        validation_split=0.2,
        verbose=0,
        callbacks=[PrintEvery100Epochs()]
    )

# ================================
# CREATE TEST SEQUENCES
# ================================
def create_test_sequences(df, seq_length, features):
    X_test = []

    for engine_id in df['engine_id'].unique():
        engine_data = df[df['engine_id'] == engine_id].reset_index(drop=True)

        if len(engine_data) >= seq_length:
            seq = engine_data.loc[len(engine_data)-seq_length:, features].values
        else:
            padding = np.zeros((seq_length - len(engine_data), len(features)))
            seq = np.vstack((padding, engine_data[features].values))

        X_test.append(seq)

    return np.array(X_test)

X_test = create_test_sequences(test, seq_length, features)

print("Test shape:", X_test.shape)

# ================================
# PREDICTION
# ================================
lstm_pred = model.predict(X_test).flatten()

# RESCALE BACK
lstm_pred = lstm_pred * 125.0

actual = rul.values.flatten()

# ================================
# METRICS
# ================================
rmse = np.sqrt(mean_squared_error(actual, lstm_pred))
r2 = r2_score(actual, lstm_pred)  

print("\nFinal LSTM RMSE:", rmse)
print("Final LSTM R2 Score:", r2)

# ================================
# PLOT RESULTS
# ================================
plt.figure(figsize=(10,5))
plt.plot(actual, label="Actual RUL")
plt.plot(lstm_pred, label="LSTM Predicted")

plt.title(f"LSTM Results\nRMSE = {rmse:.2f}, R² = {r2:.3f}")
plt.xlabel("Engine Index")
plt.ylabel("RUL")

plt.legend()
plt.grid()
plt.show()
